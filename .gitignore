# --- OS junk ---
.DS_Store
Thumbs.db

# --- Secrets & credentials (never commit these) ---
.env
.env.*
*.pem
*.key
*credentials*
*secrets*
*token*
*.oauth
composio.json
.aws/
.hermes/

# --- Docker (docker-101, aws-deploy-demo) ---
*.log
.docker/

# --- Node ---
node_modules/
npm-debug.log*
dist/
build/

# --- Python ---
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/

# --- Terraform / IaC, if you end up using it for AWS ---
*.tfstate
*.tfstate.*
.terraform/
llm-training/terraform/files/
llm-training/terraform/*.tfvars
!llm-training/terraform/terraform.tfvars.example

# --- Editor ---
.vscode/
.idea/

# --- Claude Code worktrees ---
.claude/worktrees/

# --- llm-training (Track 3): model weights are large/binary, never commit ---
llm-training/checkpoints/

# The blanket "*.log" rule above (added for docker-101/aws-deploy-demo) would
# otherwise silently swallow experiments/*/training.log, which the core
# design spec requires to be committed as part of each run's reproducibility
# record.
!llm-training/experiments/**/training.log

# The blanket "*token*" rule above (Secrets & credentials section) also
# matches the tokenizer source/tests by substring — "tokenizer" contains
# "token" — silently swallowing legitimate source files with no error.
!llm-training/src/tokenizer.py
!llm-training/tests/test_tokenizer.py
